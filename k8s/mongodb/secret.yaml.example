# ============================================================
# MongoDB Secret
# ============================================================
# IMPORTANT: This is an EXAMPLE file. Never commit real secrets to git.
#
# Usage:
#   1. Copy this to secret.yaml
#   2. Replace the base64 values with your own:
#      echo -n "your-password" | base64
#   3. Apply: kubectl apply -f secret.yaml
#
# In production, use an external secret manager (AWS Secrets Manager,
# HashiCorp Vault, etc.) with the External Secrets Operator.
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-secret
  namespace: baykar-app
type: Opaque
data:
  # echo -n "admin" | base64
  mongo-root-username: YWRtaW4=
  # echo -n "changeme-in-production" | base64
  mongo-root-password: Y2hhbmdlbWUtaW4tcHJvZHVjdGlvbg==
